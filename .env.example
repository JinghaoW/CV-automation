# CV-automation Environment Variables
# Copy this to .env and fill in your values
# (Environment variables always override config.py values)

# --------------------------------------------------------------------------
# Required: API Keys
# --------------------------------------------------------------------------

# OpenAI API key for CV parsing and job evaluation
OPENAI_API_KEY=sk-...

# --------------------------------------------------------------------------
# Required: Gmail Configuration
# --------------------------------------------------------------------------

# Gmail address to send the daily report from
GMAIL_SENDER=your-email@gmail.com

# 16-character Gmail App Password (no spaces)
# Get one at: https://support.google.com/accounts/answer/185833
GMAIL_APP_PASS=abcd efgh ijkl mnop

# Email address to receive the daily report
GMAIL_RECIPIENT=recipient@example.com

# --------------------------------------------------------------------------
# Optional: File Paths
# --------------------------------------------------------------------------

# Path to your CV PDF
CV_PATH=cv/CV.pdf

# --------------------------------------------------------------------------
# Optional: LLM Configuration
# --------------------------------------------------------------------------

# LLM provider: openai, deepseek, gemini, openrouter, ollama
LLM_PROVIDER=openai

# Model name for the selected provider
LLM_MODEL=gpt-4o-mini

# API key for LLM (if different from provider-specific key)
LLM_API_KEY=

# Base URL for OpenAI-compatible providers
LLM_BASE_URL=

# Request timeout in seconds
LLM_TIMEOUT=60

# Maximum retry attempts for LLM calls
LLM_MAX_RETRIES=3

# Temperature for LLM requests (0-1)
LLM_TEMPERATURE=0.2

# --------------------------------------------------------------------------
# Optional: Job Search
# --------------------------------------------------------------------------

# Filter jobs by country (e.g., "United States", "United Kingdom", "Remote")
# Leave blank to include all locations
COUNTRY=

# Email subject for the daily report
EMAIL_SUBJECT=Daily Job Search Report

# --------------------------------------------------------------------------
# Optional: Celery/Scheduler
# --------------------------------------------------------------------------

# Redis broker URL for Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis result backend for Celery
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Schedule hour (UTC) for the daily pipeline run
SCHEDULE_HOUR_UTC=7

# Schedule minute (UTC) for the daily pipeline run
SCHEDULE_MINUTE_UTC=0

# --------------------------------------------------------------------------
# Optional: API Server
# --------------------------------------------------------------------------

# CORS origins allowed for API requests (comma-separated)
CORS_ORIGINS=*

# Enable debug mode (shows detailed errors)
DEBUG=false

# --------------------------------------------------------------------------
# Example Configuration
# --------------------------------------------------------------------------

# Here's a complete working example:
#
# OPENAI_API_KEY=sk-proj-abc123...
# GMAIL_SENDER=myemail@gmail.com
# GMAIL_APP_PASS=abcd efgh ijkl mnop
# GMAIL_RECIPIENT=myemail@gmail.com
# CV_PATH=cv/CV.pdf
# LLM_PROVIDER=openai
# COUNTRY=United States
# CELERY_BROKER_URL=redis://localhost:6379/0

